{
  "name": "vscode-code-assistant-pro",
  "displayName": "Prompting Pro",
  "description": "Prompting Pro core engine + Chrome extension for Lucario/Trinity tri-model prompt enhancement.",
  "version": "0.0.2",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:codeAssistant.generateCode",
    "onCommand:codeAssistant.setApiKey",
    "onCommand:codeAssistant.enhancePrompt",
    "onCommand:codeAssistant.showTrainingDataReport",
    "onCommand:codeAssistant.trainPromptEnhancer"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeAssistant.generateCode",
        "title": "Code Assistant: Generate Working Code"
      },
      {
        "command": "codeAssistant.setApiKey",
        "title": "Code Assistant: Set API Key"
      },
      {
        "command": "codeAssistant.enhancePrompt",
        "title": "Code Assistant: Enhance Prompt (Trinity Fusion)"
      },
      {
        "command": "codeAssistant.showTrainingDataReport",
        "title": "Code Assistant: Show Training Data Report"
      },
      {
        "command": "codeAssistant.trainPromptEnhancer",
        "title": "Code Assistant: Train Prompt Enhancer (Lucario)"
      }
    ],
    "configuration": {
      "title": "Code Assistant",
      "properties": {
        "codeAssistant.endpoint": {
          "type": "string",
          "default": "https://api.openai.com/v1/chat/completions",
          "description": "OpenAI-compatible chat completions endpoint."
        },
        "codeAssistant.apiKey": {
          "type": "string",
          "default": "",
          "description": "Fallback API key used only when Secret Storage is empty. Prefer the Set API Key command."
        },
        "codeAssistant.model": {
          "type": "string",
          "default": "gpt-5.1",
          "description": "Model name used for code generation."
        },
        "codeAssistant.temperature": {
          "type": "number",
          "default": 0.2,
          "minimum": 0,
          "maximum": 1,
          "description": "Sampling temperature; lower values increase determinism."
        },
        "codeAssistant.maxTokens": {
          "type": "number",
          "default": 1800,
          "minimum": 200,
          "maximum": 8192,
          "description": "Maximum completion tokens."
        },
        "codeAssistant.timeoutMs": {
          "type": "number",
          "default": 60000,
          "minimum": 5000,
          "maximum": 300000,
          "description": "Request timeout in milliseconds."
        },
        "codeAssistant.includeWorkspaceContext": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, include active file and selection context in prompt enhancement."
        },
        "codeAssistant.trainingExamplesLimit": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "maximum": 10,
          "description": "Maximum number of training examples injected into enhanced prompts."
        },
        "codeAssistant.defaultFusionProfile": {
          "type": "string",
          "default": "lucario",
          "enum": [
            "lucario",
            "trinity",
            "promptcraft",
            "juma",
            "openmanus"
          ],
          "description": "Default fusion profile shown to users when enhancing prompts."
        }
      }
    }
  },
  "scripts": {
    "lint": "node --check extension.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0"
  }
}
