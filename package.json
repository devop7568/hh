{
  "name": "vscode-code-assistant-pro",
  "displayName": "Code Assistant Pro",
  "description": "Advanced VS Code code-generation assistant that returns production-ready code with implementation steps.",
  "version": "0.0.2",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:codeAssistant.generateCode",
    "onCommand:codeAssistant.setApiKey",
    "onCommand:codeAssistant.hailMaryBuild"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeAssistant.generateCode",
        "title": "Code Assistant: Generate Working Code"
      },
      {
        "command": "codeAssistant.setApiKey",
        "title": "Code Assistant: Set API Key"
      },
      {
        "command": "codeAssistant.hailMaryBuild",
        "title": "Code Assistant: Hail Mary AI Build"
      }
    ],
    "configuration": {
      "title": "Code Assistant",
      "properties": {
        "codeAssistant.endpoint": {
          "type": "string",
          "default": "https://api.openai.com/v1/chat/completions",
          "description": "OpenAI-compatible chat completions endpoint."
        },
        "codeAssistant.apiKey": {
          "type": "string",
          "default": "",
          "description": "Optional API key. Leave empty for local/self-hosted endpoints that do not require bearer auth."
        },
        "codeAssistant.model": {
          "type": "string",
          "default": "gpt-5.1",
          "description": "Model name used for code generation."
        },
        "codeAssistant.temperature": {
          "type": "number",
          "default": 0.2,
          "minimum": 0,
          "maximum": 1,
          "description": "Sampling temperature; lower values increase determinism."
        },
        "codeAssistant.maxTokens": {
          "type": "number",
          "default": 1800,
          "minimum": 200,
          "maximum": 8192,
          "description": "Maximum completion tokens."
        },
        "codeAssistant.timeoutMs": {
          "type": "number",
          "default": 60000,
          "minimum": 5000,
          "maximum": 300000,
          "description": "Request timeout in milliseconds."
        },
        "codeAssistant.hailMaryMaxAttempts": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 8,
          "description": "Maximum retries when validating Hail Mary JSON output."
        },
        "codeAssistant.mcpTools": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Optional list of available MCP/tool names passed to Hail Mary prompting."
        },
        "codeAssistant.enableCodeCheck": {
          "type": "boolean",
          "default": true,
          "description": "Run a local syntax checker on generated JavaScript/TypeScript before returning results."
        }
      }
    }
  },
  "scripts": {
    "lint": "node --check extension.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0"
  }
}
