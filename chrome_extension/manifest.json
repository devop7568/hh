{
  "manifest_version": 3,
  "name": "Prompting Pro \u2014 Lucario Trinity",
  "description": "Top-tier prompt enhancer that fuses PromptCraft, Juma, and OpenManus into one OP workflow.",
  "version": "3.0.0",
  "action": {
    "default_title": "Prompting Pro",
    "default_popup": "src/popup.html"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "options_page": "src/options.html",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
